{
  "name": "react-bulk-excel-import",
  "version": "0.5.2",
  "description": "One-line Excel/CSV bulk import for React — built-in modal UI with validation preview, error highlighting and progress. Headless hook also included.",
  "keywords": [
    "react",
    "excel",
    "excel-import",
    "csv",
    "csv-import",
    "bulk-import",
    "spreadsheet",
    "spreadsheet-import",
    "xlsx",
    "sheetjs",
    "validation",
    "import-modal",
    "file-upload",
    "data-import",
    "react-component",
    "hook",
    "headless",
    "typescript"
  ],
  "author": "Vivek Mishra <Vivekmishra1209@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vivek1209-star-blog/react-bulk-excel-import.git"
  },
  "homepage": "https://github.com/vivek1209-star-blog/react-bulk-excel-import#readme",
  "bugs": {
    "url": "https://github.com/vivek1209-star-blog/react-bulk-excel-import/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external react --external react-dom",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
